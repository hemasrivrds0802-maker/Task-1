#4 heirarchial inheritance
class parent:
    def display(self):
        print("parent class")
class child1(parent):
    pass
class child2(parent):
    pass
obj1=child1()
obj2=child2()
obj1.display()
obj2.display()

#5 hybrid inheritance
class A:
    def fun1(self):
        print("class A")
class B(A):
    def fun2(self):
        print("clss B")
class C(A):
    def fun3(self):
        print("class C")
class D(B,C):
    pass

obj=D()
obj.fun1()
obj.fun2()
obj.fun3()
# Abstraction
#1
from abc import ABC,abstractmethod
class vehicle(ABC):
    @abstractmethod
    def start(self):
        pass
class car(vehicle):
    def start(self):
        print("car starts with key")
c=car()
c.start()

