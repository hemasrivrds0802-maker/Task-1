#Function overriding
class Animal:
    def sound(self):
        print("Animal makes sounds")
class dog(Animal):
    def sound(self):
        print("Dog barks")
class cat(Animal):
    def sound(self):
        print(":cat mewos")
d=dog()
c=cat()
d.sound()
c.sound()

#Encapsulation
#Public
class student:
    name="HEMA"
s=student()
print(s.name)

#Private
class student:
    __mark=100
s=student()
print(s.__mark)

#Protected
class student:
    _age=18
    s=student()
    print(s._age)

#combined
class student:
    name="Maths"
    _age=18
    __marks=100
    def private(self):
        print("Private:",self.__marks)
    s=student()
    print("Public:",s.name)
    print("Protected:",s._age)
    print("Private:",s.__marks)
    

















        
        
    
















