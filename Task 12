#Types of inheritance
#1 single inheritance
class parent:
    def display(self):
        print("This is parent class")
class child(parent):
    pass
obj=child()
obj.display()

#2 multiple inheritance
class Father:
    def fun1(self):
        print("Father class")
class Mother:
    def fun2(self):
        print("Mother class")
class Son(Father,Mother):
    pass
obj=child()
obj.fun1()
obj.fun2()

